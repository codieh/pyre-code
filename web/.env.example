# Grading service URL (default: http://localhost:8000)
# GRADING_SERVICE_URL=http://localhost:8000

# SQLite database path (default: ./data/pyre.db)
# DB_PATH=./data/pyre.db

# AI Help — optional, OpenAI-compatible endpoint
# When configured, users can get AI-powered hints without entering their own API key.
# AI_HELP_BASE_URL=https://api.openai.com/v1
# AI_HELP_API_KEY=sk-...
# AI_HELP_MODEL=gpt-4o-mini
